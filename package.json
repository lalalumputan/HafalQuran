    "expo-constants": "~18.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
